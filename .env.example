DATABASE_URL=postgresql://reps:password@localhost:5432/reps
API_KEY=your-secret-key-here
ANTHROPIC_API_KEY=sk-ant-...
# Required for "Save to account" AI key storage. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
RESEND_API_KEY=
RESEND_FROM=reps <noreply@yourdomain.com>
APP_URL=https://yourdomain.com
LEGACY_USER_ID=
DIGEST_EMAIL_TO=you@example.com
PORT=3000
LOG_LEVEL=info
LOG_DIR=/var/log/reps
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@reps.sh
